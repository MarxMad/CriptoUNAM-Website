# Igual que .env.example — copia a .env y rellena (sin secretos en el repo).

VITE_WALLET_CONNECT_PROJECT_ID=
VITE_API_BASE_URL=https://criptounam.xyz
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
VITE_PINATA_API_KEY=
VITE_PINATA_API_SECRET=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@criptounam.com

# ---------- Avalanche C-Chain (mainnet, 43114) ----------
# Front: chain + explorer (defaults ya apuntan a Avax, pero puedes override)
VITE_CHAIN_ID=43113
VITE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_EXPLORER_URL=https://testnet.snowtrace.io

# Direcciones de los contratos (se llenan tras el deploy en Avax)
# Fuji testnet (43113) — set v2: Drops apunta a PUMA v2 + Badges:
VITE_PUMA_TOKEN_ADDRESS=0xF5F8b95cA7708f092a6D70751A4BE1545472Ee1F
VITE_BADGES_CONTRACT_ADDRESS=0x44F13D4ECd24515beFB64924A7483E2C0Fb768b2
VITE_DROPS_CONTRACT_ADDRESS=0x98BfbdBfE5626c391f56B324b01B00f310A70370
VITE_BADGES_METADATA_BASE=
VITE_BADGES_CLAIM_ENDPOINT=/api/courses/auto-certificate
VITE_COURSE_PAYMENT_ENDPOINT=/api/courses/payment

# ---------- Backend serverless (NUNCA con prefijo VITE_) ----------
# Configurar en Vercel → Project → Settings → Environment Variables
MINTER_PRIVATE_KEY=
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BADGES_CONTRACT=
PUMA_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
BADGES_METADATA_BASE=
CERT_PUMA_REWARD=100

# ---------- Foundry / Deploy ----------
# Sólo en tu .env local de deploy; jamás en Vercel ni en el repo.
PRIVATE_KEY=
INITIAL_ADMIN=
SNOWTRACE_API_KEY=
AVAX_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
