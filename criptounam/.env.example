# Copia a .env y completa. No subas .env ni pongas valores reales en este archivo.
# En Vercel: mismas claves (RESEND_* se expone al cliente por vite envPrefix).

# WalletConnect / Reown
VITE_WALLET_CONNECT_PROJECT_ID=

# API pública del sitio (opcional)
VITE_API_BASE_URL=https://criptounam.xyz

# Telegram
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# Pinata (IPFS)
VITE_PINATA_API_KEY=
VITE_PINATA_API_SECRET=

# Supabase (URL + anon o publishable)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Resend (emails; prefijo RESEND_ o VITE_RESEND_)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@criptounam.com
# VITE_RESEND_API_KEY=

# Solo scripts locales / servidor, nunca en el bundle del front:
# DIRECT_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# PUMA Token / CriptoUNAM Badges (on-chain)
VITE_PUMA_TOKEN_ADDRESS=
VITE_BADGES_CONTRACT_ADDRESS=
VITE_DROPS_CONTRACT_ADDRESS=
# Endpoint serverless que firma mints del Badge desde la wallet con MINTER_ROLE.
# Si está vacío, la página /claim solo permitirá self-mint a wallets con rol.
VITE_BADGES_CLAIM_ENDPOINT=/api/badges/claim
# Base URL para metadata de NFTs (ipfs://CID/  o  https://criptounam.xyz/badges/)
VITE_BADGES_METADATA_BASE=
# Endpoint serverless que confirma pagos de cursos en PUMA (burnReward).
# Vacío = se muestra fallback manual al alumno.
VITE_COURSE_PAYMENT_ENDPOINT=/api/courses/pay
# Red principal: Arbitrum One
VITE_CHAIN_ID=42161
VITE_RPC_URL=https://arb1.arbitrum.io/rpc
VITE_EXPLORER_URL=https://arbiscan.io
